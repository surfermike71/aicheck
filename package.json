{
  "name": "aicheck",
  "productName": "AICHECK",
  "version": "0.1.1",
  "description": "Find out if your computer is ready to run Claude Code and Claude Cowork.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac zip"
  },
  "author": {
    "name": "Mike",
    "email": "surf4waves@hotmail.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.aicheck.app",
    "productName": "AICHECK",
    "npmRebuild": false,
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.44.0",
    "systeminformation": "^5.31.6"
  }
}
